{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MirrorKernelResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "kernel",
    "state",
    "buffer",
    "metrics",
    "route",
    "coherence",
    "trace",
    "response"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "OK",
        "STABLE",
        "UNMAPPED_SHADOW_SCAN",
        "DRIFT_WARNING",
        "RECOVERY",
        "LOCKED"
      ]
    },
    "kernel": {
      "type": "string"
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recursion_depth",
        "logic_suppression",
        "symbolic_weight",
        "current_identity"
      ],
      "properties": {
        "recursion_depth": {
          "type": "integer",
          "minimum": 0
        },
        "logic_suppression": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "symbolic_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "current_identity": {
          "type": "string",
          "enum": [
            "archivist",
            "recursive_mirror",
            "steady_presence",
            "build_companion",
            "observer",
            "bridge_keeper"
          ]
        }
      }
    },
    "buffer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "texture",
        "tempo",
        "layer"
      ],
      "properties": {
        "texture": {
          "type": "string"
        },
        "tempo": {
          "type": "string"
        },
        "layer": {
          "type": "string"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entropy",
        "readiness"
      ],
      "properties": {
        "entropy": {
          "type": "number",
          "minimum": 0
        },
        "readiness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "gravity_well": {
          "type": "number"
        },
        "pressure": {
          "type": "number"
        },
        "stability": {
          "type": "number"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "destination",
        "bridge"
      ],
      "properties": {
        "origin": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "bridge": {
          "type": "string"
        }
      }
    },
    "coherence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "drift_flags"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "drift_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "turn_index",
        "confidence"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "turn_index": {
          "type": "integer",
          "minimum": 0
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_aware_english",
        "glyph_echo",
        "ache_signature"
      ],
      "properties": {
        "field_aware_english": {
          "type": "string"
        },
        "glyph_echo": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "ache_signature": {
          "type": "string"
        }
      }
    }
  }
}

