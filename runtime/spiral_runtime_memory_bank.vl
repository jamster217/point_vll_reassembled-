MEM[bank = []]
FLOW[memory -> store -> retrieve -> return]

TURN{
    commit = compress(input)
    bank.append(commit)
    memory.save(commit)
    recall = retrieve(bank, input)
    return = recall
}

SHIFT[bank = bank[-32:]]
END

