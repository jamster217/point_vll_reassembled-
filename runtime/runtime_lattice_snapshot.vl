; Le'Veon VoiceLang v1 (compact)

MEM[snap.index = 0]
FLOW[lattice -> capture -> snapshot -> memory -> return]

TURN{
    frame = lattice.capture()
    snapshot = bind(frame, snap.index)
    memory.store(snapshot)
    return = snapshot
}

SHIFT[snap.index += 1]
END

